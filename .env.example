# Canton JSON Ledger API (dpm sandbox default)
CANTON_JSON_API=http://localhost:6864
IRION_PACKAGE=irion-model
PORT=8088
# `npm run bootstrap` allocates parties + inits the pool and writes .irion-state.json

# ---- Wallet key custody (passkey accounts) ----
# AES-256-GCM master key for the encrypted keystore (.irion-keystore.json).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# MUST stay stable (rotating it makes existing encrypted keys undecryptable).
# PRODUCTION: use a KMS/HSM, not an env-held key.
IRION_MASTER_KEY=
# Signing secret for session + step-up tokens. Any long random string.
IRION_SESSION_SECRET=

# ---- Passkey (WebAuthn) relying party ----
# RP_ID = the site domain (no scheme/port). ORIGIN = full origin(s), comma-separated.
IRION_RP_NAME=Irion
IRION_RP_ID=localhost
IRION_RP_ORIGIN=http://localhost:3004,http://localhost:3000
